# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Geocoding (also used for Maps Embed/Street View)
GOOGLE_MAPS_API_KEY=

# Mapbox (public token; safe to expose)
NEXT_PUBLIC_MAPBOX_TOKEN=

# URL of the Python solver (separate Vercel project rooted at /solver).
# Required in production. Should be the full URL including /api/solver, e.g.:
#   https://truco-solver.vercel.app/api/solver
PYTHON_SOLVER_URL=
